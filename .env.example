# ============================================================================
#  La Poste Tunisienne — National Reporting App  ·  environment template
#  Copy this file to `.env` and fill in real values.  NEVER commit `.env`.
# ============================================================================

# ── Flask ────────────────────────────────────────────────────────────────────
# Generate a strong key, e.g.:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-real-random-secret
FLASK_ENV=production            # production | development | testing

# Port the app listens on. If APP_PORT is busy on a LOCAL run, it auto-falls back
# to the next free port (set APP_PORT_STRICT=true to fail instead of falling back).
APP_PORT=8000
# APP_PORT_STRICT=false
# Docker host port mapping (container always listens on 8000 internally):
APP_HOST_PORT=8000

# ── Database (SQL Server) ────────────────────────────────────────────────────
# Production / Docker (SQL Server via pyodbc + ODBC Driver 18):
DATABASE_URL=mssql+pyodbc://sa:Your_Strong_Passw0rd@db:1433/lp_national?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes&Encrypt=yes
#
# Local dev WITHOUT SQL Server (quick smoke test only) — uncomment:
# DATABASE_URL=sqlite:///local_dev.db

# SQL Server "sa" password used by the docker-compose `db` service.
# Must satisfy SQL Server complexity rules (>=8 chars, upper+lower+digit+symbol).
MSSQL_SA_PASSWORD=Your_Strong_Passw0rd
MSSQL_DB=lp_national

# ── First admin user (used by `flask create-admin` / docker entrypoint) ───────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password

# ── Excel import (national + export + import) ────────────────────────────────
# Paths INSIDE the container (mounted via docker-compose) or on the host.
# National & Export share one workbook (sheets 'national' / 'export');
# Import is a separate legacy .xls file.
NATIONAL_XLSX_PATH=/data/depot2026_nettoye.xlsx
NATIONAL_SHEET_NAME=national
NATIONAL_HEADER_ROW=2          # 0-based: header is on the 3rd row
EXPORT_SHEET_NAME=export
EXPORT_HEADER_ROW=2
IMPORT_XLS_PATH=/data/import.xls
IMPORT_HEADER_ROW=0
# docker-compose mounts ./data → /data; customize the filenames here:
IMPORT_XLS_FILE=import.xls

# ── Reports / uploads ────────────────────────────────────────────────────────
REPORTS_DIR=/app/reports
UPLOADS_DIR=/app/uploads

# ── Email (OPTIONAL — per-region report emailing). Leave MAIL_ENABLED=false
#    to disable entirely. If enabled, fill SMTP creds (use an app password). ───
MAIL_ENABLED=false
MAIL_SMTP_HOST=smtp.gmail.com
MAIL_SMTP_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=                  # Gmail App Password (NOT your account password)
MAIL_FROM=
MAIL_DEFAULT_RECIPIENT=

# ── Power BI (informational only — Power BI connects directly to SQL Server) ──
# No credentials needed by this app anymore. See README "Power BI" section.
